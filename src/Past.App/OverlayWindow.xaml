<Window
    x:Class="Past.App.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Past.App">

    <Border x:Name="RootBorder" Style="{StaticResource PastPanel}">
        <Border.KeyboardAccelerators>
            <!-- Panel-wide so Esc closes regardless of which control has focus -->
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator" />
        </Border.KeyboardAccelerators>
        <Grid Margin="12" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar: drag affordance + search + close. Dragging is handled on the
                 whole panel (see code-behind), not just this grip. -->
            <Grid x:Name="TopBar" Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- drag affordance (the whole panel is draggable) -->
                <FontIcon Grid.Column="0"
                          Glyph="&#xE700;"
                          FontSize="14"
                          Opacity="0.5"
                          ToolTipService.ToolTip="Drag anywhere to move" />

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         PlaceholderText="Search clipboard history…"
                         TextChanged="OnSearchTextChanged"
                         GotFocus="OnSearchGotFocus"
                         KeyDown="OnSearchKeyDown" />

                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Click="OnCloseClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        ToolTipService.ToolTip="Close (Esc)">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>

            <!-- Horizontal card strip -->
            <ListView x:Name="ResultsList"
                      Grid.Row="1"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnItemClick"
                      SelectionChanged="OnSelectionChanged"
                      GotFocus="OnListGotFocus"
                      CharacterReceived="OnListCharacterReceived"
                      KeyDown="OnListKeyDown"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <!-- Replace the default container template entirely: its selection chrome
                     (dark rectangle + background bleed) fights the card design. The card
                     draws its own selected border/elevation via ClipCard.IsSelected. -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="4,8,10,12" />
                        <Setter Property="MinWidth" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <!-- The system focus rectangle draws a hard black box around the card.
                             Selection follows focus here, so the accent border IS the focus cue. -->
                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ClipCard">
                        <Border Width="200" Height="200"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{x:Bind CardBorderBrush, Mode=OneWay}"
                                BorderThickness="{x:Bind CardBorderThickness, Mode=OneWay}"
                                Translation="{x:Bind CardElevation, Mode=OneWay}">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- type header -->
                                <Border Grid.Row="0"
                                        Background="{x:Bind HeaderBrush}"
                                        CornerRadius="7,7,0,0"
                                        Padding="10,6">
                                    <Grid>
                                        <TextBlock Text="{x:Bind Kind}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Text="{x:Bind Age}"
                                                   Foreground="White"
                                                   Opacity="0.75"
                                                   FontSize="10"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>

                                <!-- body: text, thumbnail, or a generic icon for images
                                     too large to render a preview for -->
                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind Body}"
                                           Margin="10,8"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind IsText}" />

                                <Image Grid.Row="1"
                                       Source="{x:Bind Thumbnail}"
                                       Margin="8"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind HasThumbnail}" />

                                <StackPanel Grid.Row="1"
                                            Visibility="{x:Bind ShowsGenericIcon}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <FontIcon Glyph="&#xEB9F;" FontSize="34" Opacity="0.55" />
                                    <TextBlock Text="{x:Bind Dimensions}"
                                               FontSize="11"
                                               Opacity="0.55"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <!-- footer -->
                                <Grid Grid.Row="2" Padding="10,6">
                                    <TextBlock Text="{x:Bind SourceApp}"
                                               FontSize="10"
                                               Opacity="0.6"
                                               HorizontalAlignment="Left"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind CharCount}"
                                               FontSize="10"
                                               Opacity="0.6"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</Window>
