<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Past design system. One place for the visual language shared by the overlay and the
      settings window: the rounded panel surface, the coloured header bar (the same treatment
      a clip card's header uses), the accent, and the text scale.
    -->

    <!-- Brand accent: the indigo of the default (TEXT) clip card, so surfaces read as one app. -->
    <Color x:Key="PastAccentColor">#4F46E5</Color>
    <SolidColorBrush x:Key="PastAccentBrush" Color="{StaticResource PastAccentColor}" />

    <x:Double x:Key="PastPanelRadius">12</x:Double>
    <x:Double x:Key="PastCardRadius">8</x:Double>

    <!-- Rounded surface used as the outer panel of both the overlay and settings. -->
    <Style x:Key="PastPanel" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PastPanelRadius}" />
    </Style>

    <!-- Accent header bar, mirroring a clip card's coloured header. -->
    <Style x:Key="PastHeaderBar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PastAccentBrush}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <!-- A rounded accent "keycap"/badge, reused for the live hotkey preview. -->
    <Style x:Key="PastBadge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PastAccentBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Text scale, matching the overlay's sizes. -->
    <Style x:Key="PastHeaderTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PastSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PastCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PastBadgeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
